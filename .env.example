# ============================================
#   QuillGlow Discord Bot - Environment Config
# ============================================

# Discord Bot Credentials
DISCORD_TOKEN=your_discord_bot_token_here
DISCORD_CLIENT_ID=your_discord_client_id_here
DISCORD_GUILD_ID=your_guild_id_here_for_testing

# Groq AI API
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# Bot Configuration
BOT_PREFIX=!
BOT_NAME=GlowBot
MAX_CONVERSATION_HISTORY=10

# Channel Configuration (optional - leave blank to allow all channels)
# AI_CHANNEL_IDS=channel_id_1,channel_id_2
# SUPPORT_CHANNEL_ID=channel_id_for_emotional_support

# Feature Flags
ENABLE_STRESS_GAMES=true
ENABLE_EMOTIONAL_SUPPORT=true
ENABLE_STUDY_TIPS=true

# Rate Limiting (requests per user per minute)
RATE_LIMIT_PER_USER=10
